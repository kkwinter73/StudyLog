---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE, withBase } from "../site";
import { UI, otherLang, type Lang } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  /** 一覧などで横幅を広げたいとき */
  wide?: boolean;
  /** ページの言語 */
  lang?: Lang;
  /** 言語トグルの遷移先（もう一方の言語での同等ページ。無ければトップ） */
  altUrl?: string;
}

const { title, lang = "ja", altUrl, wide = false } = Astro.props;
const description = Astro.props.description ?? UI[lang].description;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${UI[lang].tagline}`;
const containerClass = wide ? "container container-wide" : "container";
const altAbs = altUrl ? new URL(altUrl, Astro.url).href : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <link rel="alternate" hreflang={lang} href={Astro.url.href} />
    {altAbs && <link rel="alternate" hreflang={otherLang(lang)} href={altAbs} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
    {/* テーマのちらつき防止：描画前に data-theme を確定させる */}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme");
        if (saved === "light" || saved === "dark") {
          document.documentElement.dataset.theme = saved;
        }
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} altUrl={altUrl} />
    <main>
      <div class={containerClass}>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
