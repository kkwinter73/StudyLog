---
import BaseLayout from "./BaseLayout.astro";
import { LEVELS, formatDate, readingTime } from "../site";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const { title, summary, date, tags, level } = post.data;
const lv = LEVELS[level];
const mins = readingTime(post.body);
---

<BaseLayout title={title} description={summary}>
  <a class="back-link" href="/">← logs に戻る</a>

  <article>
    <header class="article-header">
      <div class="card-meta">
        <span>{formatDate(date)}</span>
        <span>·</span>
        <span>{mins} min read</span>
        <span class="badge">{lv.emoji} {lv.label}</span>
      </div>
      <h1>{title}</h1>
      <p class="article-summary">{summary}</p>
      {
        tags.length > 0 && (
          <div class="card-tags" style="margin-top:14px">
            {tags.map((t) => (
              <a class="tag" href={`/tags/${encodeURIComponent(t)}/`}>
                {t}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>

  <div class="post-nav">
    <a class="back-link" href="/">← logs 一覧</a>
    <a class="back-link" href="/tags/">tags →</a>
  </div>
</BaseLayout>
