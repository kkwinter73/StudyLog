---
import BaseLayout from "./BaseLayout.astro";
import { LEVELS, readingTime } from "../site";
import { UI, fmtDate, localizeHref, type Lang } from "../i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
  lang?: Lang;
  altUrl?: string;
}
const { post, lang = "ja", altUrl } = Astro.props;
const { title, summary, date, tags, level } = post.data;
const lv = LEVELS[level];
const mins = readingTime(post.body);
const ui = UI[lang];
---

<BaseLayout title={title} description={summary} lang={lang} altUrl={altUrl}>
  <a class="back-link" href={localizeHref(lang, "/")}>{ui.backToLogs}</a>

  <article>
    <header class="article-header">
      <div class="card-meta">
        <span>{fmtDate(date, lang)}</span>
        <span>·</span>
        <span>{mins} min read</span>
        <span class="badge">{lv.emoji} {lv.label}</span>
      </div>
      <h1>{title}</h1>
      <p class="article-summary">{summary}</p>
      {
        tags.length > 0 && (
          <div class="card-tags" style="margin-top:14px">
            {tags.map((t) => (
              <a class="tag" href={localizeHref(lang, `/tags/${encodeURIComponent(t)}/`)}>
                {t}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>

  <div class="post-nav">
    <a class="back-link" href={localizeHref(lang, "/")}>{ui.logsNav}</a>
    <a class="back-link" href={localizeHref(lang, "/tags/")}>{ui.tagsNav}</a>
  </div>
</BaseLayout>
