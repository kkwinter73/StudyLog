---
import { SITE } from "../site";
import { UI, NAV, localizeHref, otherLang, type Lang } from "../i18n";

interface Props {
  lang?: Lang;
  altUrl?: string;
}
const { lang = "ja", altUrl } = Astro.props;
const ui = UI[lang];
const path = Astro.url.pathname.replace(/\/$/, "");
const indexUrl = localizeHref(lang, "/search.json");
const brandUrl = localizeHref(lang, "/");
const toggleUrl = altUrl ?? localizeHref(otherLang(lang), "/");
---

<header class="site-header">
  <div class="container container-wide bar">
    <a class="brand" href={brandUrl} aria-label={SITE.title}>
      <span class="prompt">{SITE.prompt}</span>
      <span class="dot">$</span>
      <span>{SITE.title}</span>
    </a>

    <nav class="nav" aria-label="main navigation">
      {
        NAV.map((item) => (
          <a
            href={localizeHref(lang, item.path)}
            aria-current={path === localizeHref(lang, item.path).replace(/\/$/, "") ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="site-search">
      <input
        id="site-search-input"
        type="search"
        placeholder={ui.searchPlaceholder}
        autocomplete="off"
        aria-label={ui.searchAria}
        data-index={indexUrl}
        data-empty={ui.searchEmpty}
      />
      <div id="site-search-results" class="search-dropdown" role="listbox" hidden></div>
    </div>

    <a class="lang-toggle" href={toggleUrl} title={ui.toggleTitle} aria-label={ui.toggleTitle}>
      <span aria-hidden="true">🌐</span> {otherLang(lang).toUpperCase()}
    </a>

    <button
      class="theme-toggle"
      id="theme-toggle"
      type="button"
      aria-label="テーマ切替"
      title="ライト/ダーク切替"
    >
      <span aria-hidden="true">◐</span>
    </button>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const current =
        root.dataset.theme ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      const next = current === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      localStorage.setItem("theme", next);
    });
  })();
</script>

<script is:inline>
  (() => {
    const input = document.getElementById("site-search-input");
    const panel = document.getElementById("site-search-results");
    if (!input || !panel) return;
    const indexUrl = input.dataset.index;
    const emptyText = input.dataset.empty || "no hits";
    let posts = null;
    let loading = false;

    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c],
      );

    function load() {
      if (posts || loading) return;
      loading = true;
      fetch(indexUrl)
        .then((r) => r.json())
        .then((d) => {
          posts = d;
          if (input.value) render(input.value);
        })
        .catch(() => {
          loading = false;
        });
    }

    function render(q) {
      const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
      if (!posts || terms.length === 0) {
        panel.hidden = true;
        panel.innerHTML = "";
        return;
      }
      const hits = posts
        .filter((p) => {
          const hay = (
            p.title + " " + p.summary + " " + p.tags.join(" ") + " " + p.body
          ).toLowerCase();
          return terms.every((t) => hay.includes(t));
        })
        .slice(0, 8);

      if (hits.length === 0) {
        panel.innerHTML = '<p class="sd-empty">' + esc(emptyText) + "</p>";
      } else {
        panel.innerHTML = hits
          .map(
            (p) =>
              `<a class="sd-item" href="${esc(p.url)}">` +
              `<span class="sd-title">${esc(p.title)}</span>` +
              `<span class="sd-meta">${esc(p.emoji)} ${esc(p.tags.join(" / "))}</span>` +
              `</a>`,
          )
          .join("");
      }
      panel.hidden = false;
    }

    input.addEventListener("focus", load);
    input.addEventListener("input", () => render(input.value));
    input.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        input.value = "";
        panel.hidden = true;
        input.blur();
      }
    });
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".site-search")) panel.hidden = true;
    });
  })();
</script>
