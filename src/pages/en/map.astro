---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { UI, localizeHref, postLang, postSlug } from "../../i18n";
import { TIERS, DOMAINS } from "../../roadmap";

const LANG = "en";

const posts = await getCollection("posts");
const titleOf = new Map<string, string>();
for (const p of posts) {
  if (postLang(p) === LANG) titleOf.set(postSlug(p), p.data.title);
}
const domainById = new Map(DOMAINS.map((d) => [d.id, d]));
---

<BaseLayout title="Map" lang={LANG} altUrl={localizeHref("ja", "/map/")}>
  <a class="back-link" href={localizeHref(LANG, "/")}>{UI[LANG].backToLogs}</a>

  <div class="prose" style="margin-top:24px">
    <h1>Learning Map</h1>
    <p>
      The logs so far aren't a pile of dots — they connect into <strong>one map where each lower tier
      supports the one above it</strong>. Read top to bottom and a mental model builds up:
      on the <strong>foundations of OS and networking</strong> you <strong>build</strong> an app,
      <strong>ship</strong> it to production, <strong>defend</strong> it, and finally
      <strong>zoom out to the business &amp; marketing view</strong>. The "prerequisites" under
      each domain are the groundwork that makes it click faster if read first.
    </p>
  </div>

  <div class="roadmap">
    {
      TIERS.map((tier) => (
        <section class="tier">
          <div class="tier-head">
            <span class="tier-num">{tier.n}</span>
            <h2>{tier.en}</h2>
          </div>
          <div class="tier-grid">
            {DOMAINS.filter((d) => d.tier === tier.n).map((d) => (
              <div class="dom-card" id={`dom-${d.id}`}>
                <div class="dom-head">
                  <span class="dom-icon" aria-hidden="true">
                    {d.icon}
                  </span>
                  <h3>{d.en.label}</h3>
                </div>
                <p class="dom-blurb">{d.en.blurb}</p>
                {d.deps.length > 0 && (
                  <p class="dom-deps">
                    <span class="deps-label">prereq</span>
                    {d.deps.map((dep) => (
                      <a class="dep-chip" href={`#dom-${dep}`}>
                        {domainById.get(dep)?.icon} {domainById.get(dep)?.en.label}
                      </a>
                    ))}
                  </p>
                )}
                <ol class="dom-list">
                  {d.slugs.map((slug) => (
                    <li>
                      <a href={localizeHref(LANG, `/posts/${slug}/`)}>{titleOf.get(slug) ?? slug}</a>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
          </div>
          {tier.n < TIERS.length && <div class="tier-arrow" aria-hidden="true">↓</div>}
        </section>
      ))
    }
  </div>
</BaseLayout>
